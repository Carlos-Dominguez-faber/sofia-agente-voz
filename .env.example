# =============================================================
# agente-voz-ghl — credentials template
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# =============================================================

# -------------------------------------------------------------
# RETELL (voice: STT + TTS + call orchestration)
# -------------------------------------------------------------
RETELL_API_KEY=
RETELL_INBOUND_AGENT_ID=        # filled by /setup
RETELL_OUTBOUND_AGENT_ID=       # filled by /setup

# -------------------------------------------------------------
# TWILIO (phone number — connected to Retell via Elastic SIP Trunk)
# -------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=            # E.164, with + and country code

# -------------------------------------------------------------
# GOHIGHLEVEL (CRM + calendar + pipeline — a single Location)
# -------------------------------------------------------------
HIGHLEVEL_PIT=                  # Private Integration Token (scopes: contacts, calendars, opportunities)
HIGHLEVEL_LOCATION_ID=
HIGHLEVEL_CALENDAR_ID=          # "Valoración dental" calendar
HIGHLEVEL_PIPELINE_ID=          # "Nuevos Pacientes" pipeline
HIGHLEVEL_STAGE_ID=             # default stage (Cita Agendada)

# -------------------------------------------------------------
# ANTHROPIC (in-call brain + post-call analysis)
# -------------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------------
# MODAL — authenticates via CLI, NOT through this file.
#   modal token new     (once)
#   modal deploy app/main.py::modal_app
#   (the ::modal_app suffix is required — Modal looks for a variable named
#    `app` by default, and ours is `modal_app`)
# There is no MODAL_TOKEN variable in this project.
# Runtime secrets are loaded from the Modal Secret `agente-voz-credentials`.
# -------------------------------------------------------------

# MODAL (URL publica del backend, la imprime `modal deploy`)
MODAL_URL=

# -------------------------------------------------------------
# DASHBOARD (panel del cliente)
#
# DASHBOARD_API_TOKEN protege los endpoints de lectura, que devuelven
# transcripciones y datos de pacientes. Es una credencial servidor-a-servidor:
# el navegador NUNCA la ve. El panel la guarda del lado del servidor y proxea
# cada peticion. Nada de NEXT_PUBLIC_.
#
# Generala, no la elijas:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Va en los dos lados: en el Modal Secret `agente-voz-credentials` y en el
# entorno del panel. Si no coinciden, el panel recibe 401.
# -------------------------------------------------------------
DASHBOARD_API_TOKEN=

# Origenes permitidos para CORS, separados por coma. Vacio es lo correcto en un
# despliegue normal: el panel proxea por su propio servidor y el navegador nunca
# llama a esta API entre origenes distintos.
DASHBOARD_ORIGIN=
