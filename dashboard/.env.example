# Panel — variables SOLO de servidor.
# Ninguna lleva NEXT_PUBLIC_: ese prefijo inyecta el valor en el bundle del
# navegador, y eso convierte un token en un token publicado.

# URL publica del backend en Modal (la imprime `modal deploy`).
BACKEND_URL=

# Debe coincidir EXACTAMENTE con DASHBOARD_API_TOKEN del backend.
# Si no coinciden, el panel recibe 401 en todo.
DASHBOARD_API_TOKEN=

# La contraseña del panel. Un cliente, una contraseña.
#   python3 -c "import secrets; print(secrets.token_urlsafe(12))"
DASHBOARD_PASSWORD=

# Firma la cookie de sesion. No tiene relacion con la contraseña.
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SESSION_SECRET=
